# ─── Resend ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@artisell.com

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
